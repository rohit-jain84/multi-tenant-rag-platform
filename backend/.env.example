# =============================================================================
# Multi-Tenant RAG Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@postgres:5432/ragplatform

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- LLM ---
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini
LLM_PRICE_PROMPT_PER_1K=0.00015
LLM_PRICE_COMPLETION_PER_1K=0.0006

# --- Reranker ---
COHERE_API_KEY=your-cohere-key-here
RERANKER_TYPE=cohere
# Local fallback model (used if Cohere unavailable or RERANKER_TYPE=cross_encoder)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Retrieval Defaults ---
DEFAULT_TOP_K=20
DEFAULT_TOP_N=5
RRF_K=60
RERANK_SCORE_THRESHOLD=0.3

# --- Chunking Defaults ---
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_CHUNKING_STRATEGY=semantic
SEMANTIC_SIMILARITY_THRESHOLD=0.75

# --- Rate Limiting ---
DEFAULT_RATE_LIMIT_QPM=60

# --- Cache ---
QUERY_CACHE_TTL_SECONDS=300

# --- Admin ---
ADMIN_API_KEY=admin-secret-key-change-me
